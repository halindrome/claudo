{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/cmm-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/agent-cmm-gate.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/session-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__codebase-memory-mcp__index_repository|mcp__codebase-memory-mcp__index_status",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/cmm-sentinel-writer.sh"
          }
        ]
      },
      {
        "matcher": "mcp__codebase-memory-mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/track-cmm-calls.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/context-mode-event-logger.sh",
            "_comment": "optional: Context Mode MCP event logger (no-ops if Context Mode not installed)"
          }
        ]
      },
      {
        "matcher": "mcp__context-mode__ctx_execute|mcp__context-mode__ctx_stats|mcp__context-mode__ctx_index|mcp__context-mode__ctx_fetch_and_index|mcp__context-mode__ctx_batch_execute|mcp__context-mode__ctx_execute_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/context-mode-sentinel-writer.sh",
            "_comment": "optional: writes Context Mode sentinel to unblock session-gate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/ahby/Sources/claudo/.claude/hooks/context-mode-pre-compact.sh",
            "_comment": "optional: Context Mode MCP pre-compaction snapshot (no-ops if not installed)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__codebase-memory-mcp__index_repository",
      "mcp__codebase-memory-mcp__index_status",
      "mcp__codebase-memory-mcp__list_projects",
      "mcp__codebase-memory-mcp__delete_project",
      "mcp__codebase-memory-mcp__get_architecture",
      "mcp__codebase-memory-mcp__get_graph_schema",
      "mcp__codebase-memory-mcp__search_graph",
      "mcp__codebase-memory-mcp__search_code",
      "mcp__codebase-memory-mcp__query_graph",
      "mcp__codebase-memory-mcp__get_code_snippet",
      "mcp__codebase-memory-mcp__trace_call_path",
      "mcp__codebase-memory-mcp__detect_changes",
      "mcp__codebase-memory-mcp__manage_adr",
      "mcp__codebase-memory-mcp__ingest_traces",
      "mcp__context-mode__ctx_execute",
      "mcp__context-mode__ctx_search",
      "mcp__context-mode__ctx_index",
      "mcp__context-mode__ctx_fetch_and_index",
      "mcp__context-mode__ctx_batch_execute",
      "mcp__context-mode__ctx_execute_file",
      "mcp__context-mode__ctx_stats",
      "mcp__context-mode__ctx_doctor",
      "mcp__context-mode__ctx_upgrade"
    ]
  }
